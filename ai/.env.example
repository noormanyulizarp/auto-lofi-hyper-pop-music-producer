# ─── AI Provider Keys (copy to .env and fill in) ────

# OpenRouter — primary LLM gateway (8 free models)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# GLM Z.ai Direct — bypass OpenRouter for lower latency
GLM_ZAI_API_KEY=your-glm-zai-api-key-here
GLM_ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# GLM via Anthropic-compatible endpoint (z.ai)
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your-glm-zai-api-key-here

# HeartMuLa (local music generation service)
HEARTMULA_API_KEY=
HEARTMULA_BASE_URL=http://localhost:8000

# GLM Web Services (search, reader)
GLM_API_TOKEN=your-glm-api-token-here
GLM_WEB_SEARCH_URL=https://api.z.ai/api/mcp/web_search_prime/mcp
GLM_WEB_READER_URL=https://api.z.ai/api/mcp/web_reader/mcp

# GitHub
GITHUB_PAT=your-github-pat-here
