# .env.test - Test Environment Configuration
# Application Settings
DEBUG=true
TESTING=true
HOST=127.0.0.1
PORT=8001
SECRET_KEY=test-secret-key-not-for-production

# Database (Test Database)
DATABASE_URL=sqlite:///./test.db
# For PostgreSQL testing:
# DATABASE_URL=postgresql://test:test@localhost:5432/test_automusic

# Redis (Test Redis)
REDIS_URL=redis://localhost:6379/1

# OpenRouter (Test Keys - should be mocked in tests)
OPENROUTER_API_KEY=test-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# HeartMuLa (Test Keys - should be mocked in tests)
HEARTMULA_API_KEY=test-heartmula-key
HEARTMULA_BASE_URL=https://api.heartmula.com/v1

# GLM Services (Test Keys - should be mocked in tests)
GLM_WEB_SEARCH_API_KEY=test-glm-search-key
GLM_WEB_READER_API_KEY=test-glm-reader-key

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/test.log

# Test Settings
TEST_DATA_DIR=./tests/test_data
TEST_AUDIO_FILE=./tests/test_data/test_audio.mp3
TEST_VIDEO_FILE=./tests/test_data/test_video.mp4

# External Services (Mock Mode)
MOCK_EXTERNAL_SERVICES=true
USE_REAL_APIS=false

# Performance Testing
BENCHMARK_ENABLED=false
BENCHMARK_ITERATIONS=10

# Test Timeouts
REQUEST_TIMEOUT=30
ASYNC_TIMEOUT=60

# Test File Paths
UPLOAD_DIR=./test_uploads
CACHE_DIR=./test_cache
LOGS_DIR=./test_logs

# CORS (Test Origins)
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:8001"]

# Rate Limiting (Test Settings)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# Security (Test Settings)
SECURITY_HEADERS_ENABLED=true
CORS_ENABLED=true

# Monitoring (Test Settings)
METRICS_ENABLED=false
HEALTH_CHECK_ENABLED=true

# AI Provider Settings (Test)
AI_PROVIDER_TIMEOUT=10
AI_PROVIDER_MAX_RETRIES=3
AI_PROVIDER_FALLBACK_ENABLED=true

# Audio Processing (Test)
AUDIO_SAMPLE_RATE=22050
AUDIO_DURATION=5
AUDIO_FORMAT=mp3

# Video Processing (Test)
VIDEO_RESOLUTION=640x480
VIDEO_FPS=30
VIDEO_CODEC=h264

# Test Mode Flags
SKIP_EXTERNAL_TESTS=true
SKIP_SLOW_TESTS=false
SKIP_INTEGRATION_TESTS=false
RUN_ONLY_UNIT_TESTS=false
RUN_ONLY_INTEGRATION_TESTS=false

# Performance Thresholds
MAX_RESPONSE_TIME=5.0
MAX_CONCURRENT_REQUESTS=100
MAX_MEMORY_USAGE=512